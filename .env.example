# Connection string for PostgreSQL
DATABASE_URL=postgres://taskuser:taskpass@localhost:5432/taskdb?sslmode=disable

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Token lifetime, ms format (168h = 7 days)
JWT_TTL=168h

# Port the API listens on
PORT=8080

# Allowed browser origin(s) for CORS, comma separated
CORS_ORIGIN=http://localhost:3000

# Comma-separated emails that receive the admin role on signup
ADMIN_EMAILS=admin@example.com

# Directory where uploaded attachments are stored
UPLOAD_DIR=./uploads
